ENVIRONMENT=local
HTTP_ADDR=:8080

# Telegram
BOT_TOKEN=dev-bot-token
WEBHOOK_SECRET=change-me
TELEGRAM_POLLING=true
TELEGRAM_POLL_TIMEOUT_SEC=30

# Storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/streamingbot?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Bunny Stream
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_API_BASE_URL=https://video.bunnycdn.com
BUNNY_EMBED_BASE_URL=https://iframe.mediadelivery.net/embed
# Optional extra signing generated by this app (not Bunny token auth)
BUNNY_TOKEN_AUTH_KEY=

# App behavior
ACCESS_LINK_TTL_MINUTES=1440
REVIEW_DELAY_HOURS=24
RATE_LIMIT_PER_MINUTE=10
LOG_LEVEL=info
